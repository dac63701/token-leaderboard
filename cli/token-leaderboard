#!/usr/bin/env bash

# token-leaderboard - CLI tool to read OpenCode's local SQLite DB
# and upload token usage to a leaderboard server.
#
# Dependencies: sqlite3, curl (zero additional deps)

set -o pipefail

# ============================================================
# Version
# ============================================================
SCRIPT_VERSION="2.0"

# ============================================================
# Paths
# ============================================================
CONFIG_DIR="${HOME}/.config/token-leaderboard"
CONFIG_FILE="${CONFIG_DIR}/config"
UPLOADED_FILE="${CONFIG_DIR}/uploaded"
SESSION_STATE_FILE="${CONFIG_DIR}/session_state"
DB="${HOME}/.local/share/opencode/opencode.db"
CLAUDE_CODE_DIR="${HOME}/.claude/projects"
CODEX_CLI_DIR="${HOME}/.codex/sessions"

# ============================================================
# Defaults
# ============================================================
NICKNAME=""
SERVER_URL="https://token.dac63701.com"
AUTO=0
AUTO_UPDATE=1
AUTO_INTERVAL=10
GITHUB_TOKEN=""

# ============================================================
# Flag defaults
# ============================================================
HELP=false
CONFIG_ONLY=false
AUTO_MODE=false
RESET_MODE=false
VERSION_ONLY=false
LOGIN_MODE=false
UPDATE_MODE=false
PRICING_MODE=false
PRICING_MODEL=""
FIRST_RUN=false
UNINSTALL_MODE=false

# ============================================================
# Parse flags
# ============================================================
while [ $# -gt 0 ]; do
  case "$1" in
    --help)     HELP=true; shift ;;
    --config)   CONFIG_ONLY=true; shift ;;
    --auto)     AUTO_MODE=true; shift ;;
    --reset)    RESET_MODE=true; shift ;;
    --version)  VERSION_ONLY=true; shift ;;
    --login)    LOGIN_MODE=true; shift ;;
    --update)   UPDATE_MODE=true; shift ;;
    --pricing)
      PRICING_MODE=true
      if [ $# -gt 1 ] && ! echo "$2" | grep -q "^--"; then
        PRICING_MODEL="$2"
        shift
      fi
      shift
      ;;
    --first-run)  FIRST_RUN=true; shift ;;
    --uninstall)  UNINSTALL_MODE=true; shift ;;
    *)
      echo "Unknown flag: $1"
      echo "Usage: token-leaderboard [--help] [--config] [--auto] [--reset] [--version] [--login] [--update] [--pricing [model]] [--uninstall]"
      exit 1
      ;;
  esac
done

# ============================================================
# Helper: print usage
# ============================================================
usage() {
  cat <<'EOF'
token-leaderboard — Upload OpenCode token usage to a leaderboard server.

Usage:
  token-leaderboard                        Run interactively (prompts if config missing)
  token-leaderboard --help                 Show this help
  token-leaderboard --config               Print current configuration
  token-leaderboard --auto                 Run silently in loop (requires AUTO=1 in config)
  token-leaderboard --reset                Clear uploaded sessions and re-upload everything
  token-leaderboard --version              Print version and exit
  token-leaderboard --login                Authenticate with GitHub (device flow)
  token-leaderboard --update               Self-update from server
  token-leaderboard --pricing [model]      Show pricing info (all models or specific)
  token-leaderboard --first-run            One-shot upload with minimal output (used by install)
  token-leaderboard --uninstall            Remove CLI, config, and shell hooks

Configuration: ~/.config/token-leaderboard/config
  NICKNAME=<your-name>
  SERVER_URL=<leaderboard-server-url>
  AUTO=0|1
  AUTO_INTERVAL=<minutes>        (default 10)
  AUTO_UPDATE=0|1                  (default 1)
  GITHUB_TOKEN=<token>

Uploaded sessions: ~/.config/token-leaderboard/uploaded
Session state:     ~/.config/token-leaderboard/session_state
EOF
}

# ============================================================
# --help flag
# ============================================================
if [ "$HELP" = true ]; then
  usage
  exit 0
fi

# ============================================================
# --version flag
# ============================================================
if [ "$VERSION_ONLY" = true ]; then
  echo "token-leaderboard v${SCRIPT_VERSION}"
  exit 0
fi

# ============================================================
# Dependencies check
# ============================================================
check_deps() {
  local missing=false

  if ! command -v sqlite3 &>/dev/null; then
    echo "Error: sqlite3 not found. Please install sqlite3 first."
    missing=true
  fi

  if ! command -v curl &>/dev/null; then
    echo "Error: curl not found. Please install curl first."
    missing=true
  fi

  if [ "$missing" = true ]; then
    exit 1
  fi
}

check_deps

# ============================================================
# JSON parsing helpers
# ============================================================
parse_json() {
  local key="$1"
  grep -o "\"$key\": *\"[^\"]*\"" | sed "s/.*\"$key\": *\"//;s/\"//"
}
parse_json_value() {
  local key="$1"
  grep -o "\"$key\": *[0-9.]*" | sed "s/.*\"$key\": *//"
}
parse_json_bool() {
  local key="$1"
  grep -o "\"$key\": *\(true\|false\)" | sed "s/.*\"$key\": *//"
}

# ============================================================
# String hashing helper (for session IDs from file paths)
# ============================================================
string_md5() {
  local input="$1"
  if command -v md5 &>/dev/null; then
    printf '%s' "$input" | md5
  elif command -v md5sum &>/dev/null; then
    printf '%s' "$input" | md5sum | cut -d' ' -f1
  else
    printf '%s' "$input"
  fi
}

# ============================================================
# Config file operations
# ============================================================
load_config() {
  if [ -f "$CONFIG_FILE" ]; then
    # shellcheck source=/dev/null
    source "$CONFIG_FILE"
    return 0
  fi
  return 1
}

print_config() {
  load_config || true
  echo "NICKNAME=${NICKNAME:-}"
  echo "SERVER_URL=${SERVER_URL:-https://token.dac63701.com}"
  echo "AUTO=${AUTO:-0}"
  echo "AUTO_INTERVAL=${AUTO_INTERVAL:-10}"
  echo "AUTO_UPDATE=${AUTO_UPDATE:-1}"
  echo "GITHUB_TOKEN=${GITHUB_TOKEN:+<set>}"
}

save_config() {
  mkdir -p "$CONFIG_DIR"
  cat > "$CONFIG_FILE" <<EOF
NICKNAME=$1
SERVER_URL=$2
AUTO=$3
AUTO_INTERVAL=${4:-10}
AUTO_UPDATE=${5:-1}
GITHUB_TOKEN=${6:-}
EOF
  chmod 600 "$CONFIG_FILE"
}

prompt_config() {
  local default_nickname
  default_nickname=$(hostname 2>/dev/null || echo "unknown")

  echo "=== Token Leaderboard Configuration ==="
  echo ""

  read -r -p "Enter your nickname [${default_nickname}]: " input_nickname
  NICKNAME="${input_nickname:-$default_nickname}"

  read -r -p "Enter server URL [${SERVER_URL}]: " input_url
  SERVER_URL="${input_url:-$SERVER_URL}"

  # Strip trailing slash
  SERVER_URL="${SERVER_URL%/}"

  read -r -p "Auto-upload on shell start? (0=no, 1=yes) [0]: " input_auto
  AUTO="${input_auto:-0}"

  read -r -p "Upload interval in minutes [10]: " input_interval
  AUTO_INTERVAL="${input_interval:-10}"

  read -r -p "Auto-update CLI? (0=no, 1=yes) [1]: " input_auto_update
  AUTO_UPDATE="${input_auto_update:-1}"

  save_config "$NICKNAME" "$SERVER_URL" "$AUTO" "$AUTO_INTERVAL" "$AUTO_UPDATE" "$GITHUB_TOKEN"
  echo "Configuration saved to $CONFIG_FILE"
  echo ""
}

# ============================================================
# --config flag
# ============================================================
if [ "$CONFIG_ONLY" = true ]; then
  if [ -f "$CONFIG_FILE" ]; then
    print_config
    exit 0
  else
    echo "Config not found at $CONFIG_FILE"
    echo "Run 'token-leaderboard' to create it."
    exit 1
  fi
fi

# ============================================================
# Clipboard copy helper
# ============================================================
clipcopy() {
  local text="$1"
  if command -v pbcopy &>/dev/null; then
    printf '%s' "$text" | pbcopy
    return 0
  elif command -v xclip &>/dev/null; then
    printf '%s' "$text" | xclip -selection clipboard
    return 0
  elif command -v xsel &>/dev/null; then
    printf '%s' "$text" | xsel --clipboard --input
    return 0
  elif command -v clip.exe &>/dev/null; then
    printf '%s' "$text" | clip.exe
    return 0
  fi
  return 1
}

# ============================================================
# --login flag (GitHub device auth)
# ============================================================
if [ "$LOGIN_MODE" = true ]; then
  load_config || true
  SERVER_URL="${SERVER_URL%/}"

  echo "Requesting device authorization code..."
  auth_response=$(curl -s "$SERVER_URL/api/auth/github/device" 2>/dev/null)

  user_code=$(echo "$auth_response" | parse_json "user_code")
  device_code=$(echo "$auth_response" | parse_json "device_code")
  verification_uri=$(echo "$auth_response" | parse_json "verification_uri")
  interval=$(echo "$auth_response" | parse_json_value "interval")

  if [ -z "$user_code" ] || [ -z "$device_code" ]; then
    echo "Error: Failed to get device authorization code from server."
    exit 1
  fi

  echo "Open this URL: ${verification_uri:-https://github.com/login/device}"
  echo "Enter code: $user_code"
  if clipcopy "$user_code"; then
    echo "(Code copied to clipboard!)"
  fi
  echo ""
  echo "Waiting for authentication..."

  interval="${interval:-5}"

  while true; do
    sleep "$interval"
    poll_response=$(curl -s "$SERVER_URL/api/auth/github/poll" \
      -H "Content-Type: application/json" \
      -d "{\"device_code\":\"$device_code\"}" 2>/dev/null)

    poll_status=$(echo "$poll_response" | parse_json "status")

    if [ "$poll_status" = "complete" ] || [ -z "$poll_status" ]; then
      token=$(echo "$poll_response" | parse_json "token")
      nickname=$(echo "$poll_response" | parse_json "nickname")

      if [ -n "$token" ]; then
        GITHUB_TOKEN="$token"
        NICKNAME="$nickname"
        mkdir -p "$CONFIG_DIR"
        save_config "$NICKNAME" "$SERVER_URL" "$AUTO" "$AUTO_INTERVAL" "$AUTO_UPDATE" "$GITHUB_TOKEN"
        echo "✓ Authenticated as ${nickname}"
        exit 0
      fi
    elif [ "$poll_status" = "expired" ]; then
      echo "Error: Device code expired. Please run --login again."
      exit 1
    elif [ "$poll_status" = "pending" ]; then
      continue
    else
      echo "Error: Unexpected response during polling."
      exit 1
    fi
  done
fi

# ============================================================
# --update flag (self-update)
# ============================================================
run_update() {
  load_config || true
  SERVER_URL="${SERVER_URL%/}"

  echo "Checking for updates..."
  update_response=$(curl -s "$SERVER_URL/api/cli/version" 2>/dev/null)

  latest_version=$(echo "$update_response" | parse_json "latest")
  download_url=$(echo "$update_response" | parse_json "url")
  sha256_hash=$(echo "$update_response" | parse_json "sha256")

  if [ -z "$latest_version" ] || [ -z "$download_url" ]; then
    echo "Error: Failed to check for updates from server."
    return 1
  fi

  if [ "$latest_version" = "$SCRIPT_VERSION" ]; then
    echo "Already up to date (v${SCRIPT_VERSION})"
    return 0
  fi

  echo "New version available: v${latest_version} (current: v${SCRIPT_VERSION})"

  local tmp_file
  tmp_file=$(mktemp /tmp/token-leaderboard.XXXXXX)

  if ! curl -sL -o "$tmp_file" "$download_url" 2>/dev/null; then
    echo "Error: Failed to download update."
    rm -f "$tmp_file"
    return 1
  fi

  if [ -n "$sha256_hash" ]; then
    local actual_hash
    actual_hash=$(shasum -a 256 "$tmp_file" | cut -d' ' -f1)
    if [ "$actual_hash" != "$sha256_hash" ]; then
      echo "Error: SHA256 mismatch. Expected ${sha256_hash}, got ${actual_hash}."
      rm -f "$tmp_file"
      return 1
    fi
  fi

  chmod +x "$tmp_file"

  local script_path
  script_path="$(command -v token-leaderboard 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")"
  if echo "$script_path" | grep -q "^\."; then
    script_path="$PWD/${script_path#./}"
  fi

  if ! mv "$tmp_file" "$script_path" 2>/dev/null; then
    if command -v cp &>/dev/null && cp "$tmp_file" "$script_path" 2>/dev/null; then
      rm -f "$tmp_file"
    else
      echo "Error: Could not replace script at $script_path. Try with sudo?"
      rm -f "$tmp_file"
      return 1
    fi
  fi

  echo "✓ Updated to version ${latest_version}"
  return 0
}

if [ "$UPDATE_MODE" = true ]; then
  run_update
  exit $?
fi

# ============================================================
# --pricing flag
# ============================================================
if [ "$PRICING_MODE" = true ]; then
  load_config || true
  SERVER_URL="${SERVER_URL%/}"

  if [ -n "$PRICING_MODEL" ]; then
    encoded_model=$(python3 -c "import urllib.parse; print(urllib.parse.quote('${PRICING_MODEL}'))" 2>/dev/null || echo "$PRICING_MODEL")
    pricing_response=$(curl -s "${SERVER_URL}/api/pricing?model=${encoded_model}" 2>/dev/null)
    pricing_model=$(echo "$pricing_response" | parse_json "model")
    pricing_input=$(echo "$pricing_response" | parse_json_value "input")
    pricing_output=$(echo "$pricing_response" | parse_json_value "output")
    pricing_cache_read=$(echo "$pricing_response" | parse_json_value "cache_read")
    pricing_cache_write=$(echo "$pricing_response" | parse_json_value "cache_write")

    if [ -z "$pricing_model" ]; then
      echo "No pricing data found for: ${PRICING_MODEL}"
      exit 1
    fi

    printf "Model:        %s\n" "$pricing_model"
    printf "Input:        $%.6f / 1K tokens\n" "${pricing_input:-0}"
    printf "Output:       $%.6f / 1K tokens\n" "${pricing_output:-0}"
    printf "Cache Read:   $%.6f / 1K tokens\n" "${pricing_cache_read:-0}"
    printf "Cache Write:  $%.6f / 1K tokens\n" "${pricing_cache_write:-0}"
  else
    echo "Usage: token-leaderboard --pricing <model-id>"
    echo ""
    echo "Examples:"
    echo "  token-leaderboard --pricing gpt-4o"
    echo "  token-leaderboard --pricing claude-3-5-sonnet-20241022"
    echo ""
    echo "To list all available models, visit: ${SERVER_URL}/api/pricing?model=all"
    echo "(Requires the pricing engine to be initialized on the server)"
  fi

  exit 0
fi

# ============================================================
# --first-run flag: minimal output, used by install.sh
# ============================================================
if [ "$FIRST_RUN" = true ]; then
  load_config || true
  SERVER_URL="${SERVER_URL%/}"
  echo "  Uploading tokens..."
  run_upload_cycle >/dev/null
  local exit_code=$?
  if [ "$exit_code" = "0" ]; then
    echo "  ✓ First upload complete!"
  fi
  exit "$exit_code"
fi

# ============================================================
# Load or create config
# ============================================================
if [ "$AUTO_MODE" = true ]; then
  if ! load_config; then
    exit 0
  fi
  if [ "${AUTO:-0}" != "1" ]; then
    exit 0
  fi
  # In auto mode, check for update if AUTO_UPDATE is enabled
  if [ "${AUTO_UPDATE:-1}" = "1" ]; then
    run_update >/dev/null 2>&1 || true
  fi
else
  if ! load_config; then
    prompt_config
  fi
fi

# ============================================================
# --reset flag: clear uploaded sessions
# ============================================================
if [ "$RESET_MODE" = true ]; then
  if [ -f "$UPLOADED_FILE" ]; then
    rm -f "$UPLOADED_FILE"
    echo "Cleared uploaded sessions tracking. Will re-upload all sessions."
  else
    echo "No uploaded sessions file found. Nothing to reset."
  fi
  if [ -f "$SESSION_STATE_FILE" ]; then
    rm -f "$SESSION_STATE_FILE"
    echo "Cleared session state tracking."
  fi
  if [ "$AUTO_MODE" = false ]; then
    exit 0
  fi
fi

# Strip trailing slash from SERVER_URL (in case it was set manually)
SERVER_URL="${SERVER_URL%/}"

# ============================================================
# Check DB exists (optional with multi-source)
# ============================================================
if [ ! -f "$DB" ] && [ "$AUTO_MODE" = false ]; then
  echo "Note: OpenCode DB not found at ${DB} (will try other sources)"
fi

# ============================================================
# Helper: check if session ID already uploaded
# ============================================================
is_uploaded() {
  local sid="$1"
  if [ ! -f "$UPLOADED_FILE" ]; then
    return 1
  fi
  grep -Fxq "$sid" "$UPLOADED_FILE" 2>/dev/null
}

# ============================================================
# Session state helpers
# ============================================================
load_session_state() {
  if [ -f "$SESSION_STATE_FILE" ]; then
    cat "$SESSION_STATE_FILE"
  fi
}

get_session_state() {
  local sid="$1"
  local state
  state=$(load_session_state | grep "^${sid}|" 2>/dev/null)
  echo "$state"
}

save_session_state_line() {
  local sid="$1" ti="$2" to="$3" tcr="$4" tcw="$5" tr="$6" ts="$7"
  mkdir -p "$CONFIG_DIR"
  if grep -q "^${sid}|" "$SESSION_STATE_FILE" 2>/dev/null; then
    local tmp
    tmp=$(mktemp /tmp/tl-state.XXXXXX)
    grep -v "^${sid}|" "$SESSION_STATE_FILE" > "$tmp" 2>/dev/null
    mv "$tmp" "$SESSION_STATE_FILE"
  fi
  echo "${sid}|${ti}|${to}|${tcr}|${tcw}|${tr}|${ts}" >> "$SESSION_STATE_FILE"
}

# ============================================================
# JSON escape helper
# ============================================================
json_escape() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\t'/ }"
  s="${s//$'\n'/ }"
  s="${s//$'\r'/ }"
  s=$(printf '%s' "$s" | tr -d '\000-\037\177' 2>/dev/null)
  printf '%s' "$s"
}

# ============================================================
# Multi-source readers
# ============================================================

read_opencode() {
  if [ ! -f "$DB" ]; then
    return 0
  fi
  local QUERY="
  SELECT
    id,
    IFNULL(json_extract(model, '$.id'), '') AS model_id,
    IFNULL(json_extract(model, '$.providerID'), '') AS provider,
    IFNULL(tokens_input, 0) AS tokens_input,
    IFNULL(tokens_output, 0) AS tokens_output,
    IFNULL(tokens_cache_read, 0) AS tokens_cache_read,
    IFNULL(tokens_cache_write, 0) AS tokens_cache_write,
    IFNULL(tokens_reasoning, 0) AS tokens_reasoning,
    IFNULL(cost, 0) AS cost,
    IFNULL(time_created, 0) AS time_created,
    IFNULL(time_updated, 0) AS time_updated,
    REPLACE(REPLACE(REPLACE(IFNULL(title,''), CHAR(9), ' '), CHAR(10), ' '), CHAR(13), ' ') AS title_clean
  FROM session
  WHERE tokens_input > 0
     OR tokens_output > 0
     OR tokens_cache_read > 0
     OR tokens_cache_write > 0
     OR tokens_reasoning > 0
  ORDER BY time_created ASC
  "
  while IFS=$'\t' read -r id model_id provider ti to tcr tcw tr cost ts_tc ts_tu title_rest; do
    [ -z "$id" ] && continue
    SESSION_IDS+=("$id")
    MODEL_IDS+=("$model_id")
    PROVIDERS+=("$provider")
    TOKENS_INPUT+=("$ti")
    TOKENS_OUTPUT+=("$to")
    TOKENS_CACHE_READ+=("$tcr")
    TOKENS_CACHE_WRITE+=("$tcw")
    TOKENS_REASONING+=("$tr")
    COSTS+=("$cost")
    TIMES_CREATED+=("$ts_tc")
    TIMES_UPDATED+=("$ts_tu")
    TITLES+=("$title_rest")
    SOURCES+=("opencode")
  done < <(sqlite3 -separator $'\t' "$DB" "$QUERY" 2>/dev/null)
}

# ============================================================
# Read Claude Code sessions
# ============================================================
read_claude_code() {
  local dir="$CLAUDE_CODE_DIR"
  if [ ! -d "$dir" ]; then
    return 0
  fi
  while IFS= read -r -d '' file; do
    local session_id
    session_id=$(string_md5 "$file")
    local mtime=0
    mtime=$(stat -c "%Y" "$file" 2>/dev/null) || mtime=$(stat -f "%m" "$file" 2>/dev/null) || mtime=0
    local last_line
    last_line=$(tail -1 "$file" 2>/dev/null)
    [ -z "$last_line" ] && continue
    local input_tokens output_tokens cache_creation cache_read cost model
    input_tokens=$(echo "$last_line" | parse_json_value "input_tokens")
    output_tokens=$(echo "$last_line" | parse_json_value "output_tokens")
    cache_creation=$(echo "$last_line" | parse_json_value "cache_creation_input_tokens")
    cache_read=$(echo "$last_line" | parse_json_value "cache_read_input_tokens")
    cost=$(echo "$last_line" | parse_json_value "total_cost_usd")
    model=$(grep -o '"model"[[:space:]]*:[[:space:]]*"[^"]*"' "$file" 2>/dev/null | head -1 | sed 's/"model" *: *"//;s/"//')
    input_tokens=${input_tokens:-0}
    output_tokens=${output_tokens:-0}
    cache_creation=${cache_creation:-0}
    cache_read=${cache_read:-0}
    cost=${cost:-0}
    model=${model:-unknown}
    SESSION_IDS+=("${session_id}")
    MODEL_IDS+=("${model}")
    PROVIDERS+=("")
    TOKENS_INPUT+=("${input_tokens}")
    TOKENS_OUTPUT+=("${output_tokens}")
    TOKENS_CACHE_READ+=("${cache_read}")
    TOKENS_CACHE_WRITE+=("${cache_creation}")
    TOKENS_REASONING+=("0")
    COSTS+=("${cost}")
    TIMES_CREATED+=("${mtime}")
    TIMES_UPDATED+=("${mtime}")
    TITLES+=("Claude Code session")
    SOURCES+=("claude-code")
  done < <(find "$dir" -name "*.jsonl" -type f -print0 2>/dev/null)
}

# ============================================================
# Read Codex CLI sessions
# ============================================================
read_codex_cli() {
  local dir="$CODEX_CLI_DIR"
  if [ ! -d "$dir" ]; then
    return 0
  fi
  while IFS= read -r -d '' file; do
    local session_id
    session_id=$(string_md5 "$file")
    local mtime=0
    mtime=$(stat -c "%Y" "$file" 2>/dev/null) || mtime=$(stat -f "%m" "$file" 2>/dev/null) || mtime=0
    local model
    model=$(grep -o '"model"[[:space:]]*:[[:space:]]*"[^"]*"' "$file" 2>/dev/null | head -1 | sed 's/"model" *: *"//;s/"//')
    model=${model:-unknown}
    local token_lines
    token_lines=$(grep '"token_count"' "$file" 2>/dev/null)
    [ -z "$token_lines" ] && continue
    local last_token_line
    last_token_line=$(echo "$token_lines" | tail -1)
    local input_tokens cached_input_tokens output_tokens reasoning_tokens
    input_tokens=$(echo "$last_token_line" | parse_json_value "input_tokens")
    cached_input_tokens=$(echo "$last_token_line" | parse_json_value "cached_input_tokens")
    output_tokens=$(echo "$last_token_line" | parse_json_value "output_tokens")
    reasoning_tokens=$(echo "$last_token_line" | parse_json_value "reasoning_output_tokens")
    input_tokens=${input_tokens:-0}
    cached_input_tokens=${cached_input_tokens:-0}
    output_tokens=${output_tokens:-0}
    reasoning_tokens=${reasoning_tokens:-0}
    SESSION_IDS+=("${session_id}")
    MODEL_IDS+=("${model}")
    PROVIDERS+=("")
    TOKENS_INPUT+=("${input_tokens}")
    TOKENS_OUTPUT+=("${output_tokens}")
    TOKENS_CACHE_READ+=("${cached_input_tokens}")
    TOKENS_CACHE_WRITE+=("0")
    TOKENS_REASONING+=("${reasoning_tokens}")
    COSTS+=("0")
    TIMES_CREATED+=("${mtime}")
    TIMES_UPDATED+=("${mtime}")
    TITLES+=("Codex CLI session")
    SOURCES+=("codex-cli")
  done < <(find "$dir" -name "*.jsonl" -type f -print0 2>/dev/null)
}

# ============================================================
# Read Copilot debug logs
# ============================================================
read_copilot() {
  local found_any=false
  for base in \
    "${HOME}/Library/Application Support/Code/User/workspaceStorage" \
    "${HOME}/.config/Code/User/workspaceStorage"; do
    [ ! -d "$base" ] && continue
    while IFS= read -r -d '' file; do
      local llm_requests
      llm_requests=$(grep '"llm_request"' "$file" 2>/dev/null)
      [ -z "$llm_requests" ] && continue
      local mtime=0
      mtime=$(stat -c "%Y" "$file" 2>/dev/null) || mtime=$(stat -f "%m" "$file" 2>/dev/null) || mtime=0
      local models_list
      models_list=$(echo "$llm_requests" | grep -o '"model"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/"model" *: *"//;s/"//' | sort -u)
      [ -z "$models_list" ] && continue
      while IFS= read -r model; do
        [ -z "$model" ] && continue
        local ti_total=0 to_total=0 ct_total=0
        while IFS= read -r line; do
          [ -z "$line" ] && continue
          local ti to ct
          ti=$(echo "$line" | parse_json_value "inputTokens")
          to=$(echo "$line" | parse_json_value "outputTokens")
          ct=$(echo "$line" | parse_json_value "cachedTokens")
          ti_total=$((ti_total + ${ti:-0}))
          to_total=$((to_total + ${to:-0}))
          ct_total=$((ct_total + ${ct:-0}))
        done < <(echo "$llm_requests" | grep -F "\"${model}\"")
        local session_id
        session_id=$(string_md5 "${file}-${model}")
        SESSION_IDS+=("${session_id}")
        MODEL_IDS+=("${model}")
        PROVIDERS+=("")
        TOKENS_INPUT+=("${ti_total}")
        TOKENS_OUTPUT+=("${to_total}")
        TOKENS_CACHE_READ+=("${ct_total}")
        TOKENS_CACHE_WRITE+=("0")
        TOKENS_REASONING+=("0")
        COSTS+=("0")
        TIMES_CREATED+=("${mtime}")
        TIMES_UPDATED+=("${mtime}")
        TITLES+=("Copilot session")
        SOURCES+=("copilot")
        found_any=true
      done <<< "$models_list"
    done < <(find "$base" -path "*/GitHub.copilot-chat/debug-logs/*/main.jsonl" -type f -print0 2>/dev/null)
  done
}

# ============================================================
# Read all available sources
# ============================================================
read_all_sources() {
  read_opencode
  if [ -d "$CLAUDE_CODE_DIR" ]; then
    read_claude_code
  fi
  if [ -d "$CODEX_CLI_DIR" ]; then
    read_codex_cli
  fi
  read_copilot
}

# ============================================================
# Upload cycle: query DB → filter → build JSON → upload
# ============================================================
run_upload_cycle() {
  SESSION_IDS=()
  MODEL_IDS=()
  PROVIDERS=()
  TOKENS_INPUT=()
  TOKENS_OUTPUT=()
  TOKENS_CACHE_READ=()
  TOKENS_CACHE_WRITE=()
  TOKENS_REASONING=()
  COSTS=()
  TIMES_CREATED=()
  TIMES_UPDATED=()
  TITLES=()
  SOURCES=()

  # Read from all available sources
  read_all_sources

  # Check new/delta for all entries
  IS_NEW=()
  IS_DELTA=()
  for i in "${!SESSION_IDS[@]}"; do
    local id="${SESSION_IDS[$i]}"
    local ti="${TOKENS_INPUT[$i]}"
    local to="${TOKENS_OUTPUT[$i]}"
    local tcr="${TOKENS_CACHE_READ[$i]}"
    local tcw="${TOKENS_CACHE_WRITE[$i]}"
    local tr="${TOKENS_REASONING[$i]}"
    local ts_tu="${TIMES_UPDATED[$i]}"

    if is_uploaded "$id"; then
      IS_NEW+=("0")
      local state_line
      state_line=$(get_session_state "$id")
      if [ -n "$state_line" ]; then
        local old_ti old_to old_tcr old_tcw old_tr old_ts
        old_ti=$(echo "$state_line" | cut -d'|' -f2)
        old_to=$(echo "$state_line" | cut -d'|' -f3)
        old_tcr=$(echo "$state_line" | cut -d'|' -f4)
        old_tcw=$(echo "$state_line" | cut -d'|' -f5)
        old_tr=$(echo "$state_line" | cut -d'|' -f6)
        old_ts=$(echo "$state_line" | cut -d'|' -f7)
        if [ "$ts_tu" != "$old_ts" ] && { [ "$ti" != "$old_ti" ] || [ "$to" != "$old_to" ] || [ "$tcr" != "$old_tcr" ] || [ "$tcw" != "$old_tcw" ] || [ "$tr" != "$old_tr" ]; }; then
          IS_DELTA+=("1")
        else
          IS_DELTA+=("0")
        fi
      else
        IS_DELTA+=("0")
      fi
    else
      IS_NEW+=("1")
      IS_DELTA+=("0")
    fi
  done

  UPLOAD_IDS=()
  UPLOAD_MODEL_IDS=()
  UPLOAD_PROVIDERS=()
  UPLOAD_INPUT=()
  UPLOAD_OUTPUT=()
  UPLOAD_CACHE_READ=()
  UPLOAD_CACHE_WRITE=()
  UPLOAD_REASONING=()
  UPLOAD_COSTS=()
  UPLOAD_TIMES=()
  UPLOAD_TITLES=()
  UPLOAD_IS_DELTA=()
  UPLOAD_TIMES_UPDATED=()
  UPLOAD_SOURCES=()

  for i in "${!SESSION_IDS[@]}"; do
    if [ "${IS_NEW[$i]}" = "1" ] || [ "${IS_DELTA[$i]}" = "1" ]; then
      UPLOAD_IDS+=("${SESSION_IDS[$i]}")
      UPLOAD_MODEL_IDS+=("${MODEL_IDS[$i]}")
      UPLOAD_PROVIDERS+=("${PROVIDERS[$i]}")
      UPLOAD_INPUT+=("${TOKENS_INPUT[$i]}")
      UPLOAD_OUTPUT+=("${TOKENS_OUTPUT[$i]}")
      UPLOAD_CACHE_READ+=("${TOKENS_CACHE_READ[$i]}")
      UPLOAD_CACHE_WRITE+=("${TOKENS_CACHE_WRITE[$i]}")
      UPLOAD_REASONING+=("${TOKENS_REASONING[$i]}")
      UPLOAD_COSTS+=("${COSTS[$i]}")
      UPLOAD_TIMES+=("${TIMES_CREATED[$i]}")
      UPLOAD_TITLES+=("${TITLES[$i]}")
      UPLOAD_IS_DELTA+=("${IS_DELTA[$i]}")
      UPLOAD_TIMES_UPDATED+=("${TIMES_UPDATED[$i]}")
      UPLOAD_SOURCES+=("${SOURCES[$i]}")
    fi
  done

  if [ ${#UPLOAD_IDS[@]} -eq 0 ]; then
    if [ "$AUTO_MODE" = false ]; then
      echo "No sessions to upload"
    fi
    return 0
  fi

  # Build JSON payload
  local nickname_escaped
  nickname_escaped=$(json_escape "$NICKNAME")
  local json="{\"nickname\":\"${nickname_escaped}\",\"sessions\":["
  local first=true
  for i in "${!UPLOAD_IDS[@]}"; do
    local id_escaped model_id_escaped provider_escaped title_escaped source_escaped
    id_escaped=$(json_escape "${UPLOAD_IDS[$i]}")
    model_id_escaped=$(json_escape "${UPLOAD_MODEL_IDS[$i]}")
    provider_escaped=$(json_escape "${UPLOAD_PROVIDERS[$i]}")
    title_escaped=$(json_escape "${UPLOAD_TITLES[$i]}")
    source_escaped=$(json_escape "${UPLOAD_SOURCES[$i]}")
    if [ "$first" = true ]; then first=false; else json+=","; fi
    json+="{\"id\":\"${id_escaped}\""
    json+=",\"model_id\":\"${model_id_escaped}\""
    json+=",\"provider\":\"${provider_escaped}\""
    json+=",\"input\":${UPLOAD_INPUT[$i]}"
    json+=",\"output\":${UPLOAD_OUTPUT[$i]}"
    json+=",\"cache_read\":${UPLOAD_CACHE_READ[$i]}"
    json+=",\"cache_write\":${UPLOAD_CACHE_WRITE[$i]}"
    json+=",\"reasoning\":${UPLOAD_REASONING[$i]}"
    json+=",\"cost\":${UPLOAD_COSTS[$i]}"
    json+=",\"time_created\":${UPLOAD_TIMES[$i]}"
    json+=",\"title\":\"${title_escaped}\""
    json+=",\"source\":\"${source_escaped}\""
    if [ "${UPLOAD_IS_DELTA[$i]}" = "1" ]; then
      json+=",\"delta\":true"
    fi
    json+="}"
  done
  json+="]}"

  # Upload
  local upload_endpoint="${SERVER_URL}/api/upload"

  if [ "$AUTO_MODE" = false ]; then
    echo "Uploading ${#UPLOAD_IDS[@]} session(s) to ${upload_endpoint}..."
  fi

  local response
  local curl_args=(
    -s --connect-timeout 10 --max-time 30
    -w "\n%{http_code}"
    -X POST
    -H "Content-Type: application/json"
  )
  if [ -n "$GITHUB_TOKEN" ]; then
    curl_args+=(-H "Authorization: Bearer ${GITHUB_TOKEN}")
  fi
  curl_args+=(-d "$json" "$upload_endpoint")
  response=$(curl "${curl_args[@]}" 2>/dev/null)

  local http_code body
  http_code=$(echo "$response" | tail -1)
  body=$(echo "$response" | sed '$d')

  if [ "$http_code" = "200" ]; then
    mkdir -p "$CONFIG_DIR"
    for i in "${!UPLOAD_IDS[@]}"; do
      echo "${UPLOAD_IDS[$i]}" >> "$UPLOADED_FILE"
      save_session_state_line \
        "${UPLOAD_IDS[$i]}" \
        "${UPLOAD_INPUT[$i]}" \
        "${UPLOAD_OUTPUT[$i]}" \
        "${UPLOAD_CACHE_READ[$i]}" \
        "${UPLOAD_CACHE_WRITE[$i]}" \
        "${UPLOAD_REASONING[$i]}" \
        "${UPLOAD_TIMES_UPDATED[$i]}"
    done
    if [ "$AUTO_MODE" = false ]; then
      echo "Upload successful! ${#UPLOAD_IDS[@]} session(s) uploaded."
    fi
    return 0
  else
    if [ "$AUTO_MODE" = false ]; then
      if [ -z "$http_code" ]; then
        echo "Error: Could not connect to server (${SERVER_URL})"
      else
        echo "Error: Server returned HTTP ${http_code}"
      fi
      if [ -n "$body" ]; then
        echo "Server response: $body"
        echo "---"
        echo "Tip: Check that NICKNAME is set and SERVER_URL is correct in your config."
        echo "     Run 'token-leaderboard --config' to view your settings."
      fi
    fi
    return 1
  fi
}

# ============================================================
# --uninstall flag
# ============================================================
run_uninstall() {
  local bin_path="${HOME}/.local/bin/token-leaderboard"
  local config_dir="${HOME}/.config/token-leaderboard"
  local removed=false

  # Remove CLI binary
  if [ -f "$bin_path" ]; then
    rm -f "$bin_path"
    echo "  ✓ Removed CLI: $bin_path"
    removed=true
  fi

  # Remove config directory
  if [ -d "$config_dir" ]; then
    rm -rf "$config_dir"
    echo "  ✓ Removed config: $config_dir"
    removed=true
  fi

  # Remove shell hooks
  local marker="# Token Leaderboard auto-upload"
  for rc_file in "${HOME}/.zshrc" "${HOME}/.bashrc" "${HOME}/.profile"; do
    if [ -f "$rc_file" ] && grep -qF "$marker" "$rc_file" 2>/dev/null; then
      sed -i '' '/# Token Leaderboard auto-upload/d' "$rc_file" 2>/dev/null || true
      sed -i '' '/token-leaderboard --auto/d' "$rc_file" 2>/dev/null || true
      sed -i '' '/token-leaderboard --update/d' "$rc_file" 2>/dev/null || true
      echo "  ✓ Removed shell hook from $rc_file"
      removed=true
    fi
  done

  if [ "$removed" = false ]; then
    echo "  Nothing to uninstall — Token Leaderboard not found."
    exit 0
  fi

  echo ""
  echo "  Token Leaderboard has been uninstalled."
}

if [ "$UNINSTALL_MODE" = true ]; then
  echo ""
  echo "╔══════════════════════════════════════╗"
  echo "║    Token Leaderboard Uninstaller     ║"
  echo "╚══════════════════════════════════════╝"
  echo ""
  run_uninstall
  exit 0
fi

# ============================================================
# Main: run once (interactive) or loop (auto)
# ============================================================
if [ "$AUTO_MODE" = true ]; then
  while true; do
    run_upload_cycle
    sleep "$(( ${AUTO_INTERVAL:-10} * 60 ))"
  done
else
  run_upload_cycle
  exit $?
fi